{
  "name": "@eclipse-daanse/org.eclipse.daanse.feel.langium",
  "version": "1.0.0",
  "description": "Langium-based FEEL parser with LSP support for DMN",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "langium:generate": "langium generate",
    "build": "npm run langium:generate && tsc",
    "watch": "tsc --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "langium": "^3.3.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "feelin": "^6.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.10.1",
    "husky": "^9.1.7",
    "langium-cli": "^3.3.1",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "EPL-2.0"
}
